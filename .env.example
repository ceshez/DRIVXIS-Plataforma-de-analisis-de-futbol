DATABASE_URL="postgresql://postgres:postgres@localhost:5432/drivxis?schema=public"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

STORAGE_ENDPOINT="https://example-account.r2.cloudflarestorage.com"
STORAGE_REGION="auto"
STORAGE_BUCKET="drivxis-videos"
STORAGE_ACCESS_KEY_ID="replace-me"
STORAGE_SECRET_ACCESS_KEY="replace-me"
STORAGE_PUBLIC_BASE_URL=""

